  {
    "name": "scm.files.read",
    "description": "Read a single file from a repository at an optional ref. Returns path, ref, content, and encoding.",
    "inputSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ReadFileArgs",
      "type": "object",
