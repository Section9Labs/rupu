      "properties": {
        "owner": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "platform": {
          "type": [
            "string",
            "null"
          ]
        },
        "ref": {
          "description": "Optional ref (branch / tag / sha). Defaults to repo's default branch.",
          "type": [
            "string",
            "null"
          ]
        },
        "repo": {
          "type": "string"
        }
      }
    }
  },
  {
    "name": "scm.prs.list",
    "description": "List pull/merge requests on a repository. Optional filters: state (open/closed/merged), author, limit.",
    "inputSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ListPrsArgs",
      "type": "object",
