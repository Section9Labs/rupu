[
  {
    "name": "scm.repos.list",
    "description": "List repositories the authenticated user can access on the given platform. Omit `platform` to use [scm.default].",
    "inputSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ListReposArgs",
      "type": "object",
      "properties": {
        "platform": {
          "description": "Platform to query (`github` | `gitlab`). Omit to use [scm.default].",
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  },
  {
    "name": "scm.repos.get",
    "description": "Fetch a single repository (default branch, clone URLs, visibility, description).",
    "inputSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "GetRepoArgs",
      "type": "object",
      "required": [
        "owner",
        "repo"
      ],
      "properties": {
        "owner": {
          "type": "string"
        },
        "platform": {
          "type": [
            "string",
            "null"
          ]
        },
        "repo": {
          "type": "string"
        }
      }
    }
  },
  {
