        "owner": {
          "type": "string"
        },
        "platform": {
          "type": [
            "string",
            "null"
          ]
        },
        "repo": {
          "type": "string"
        },
        "state": {
          "description": "`open` | `closed` | `merged`. Omit to list all states.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  },
