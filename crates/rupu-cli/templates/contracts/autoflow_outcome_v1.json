{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "autoflow_outcome_v1",
  "type": "object",
  "required": [
    "status"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "continue",
        "await_human",
        "await_external",
        "retry",
        "blocked",
        "complete"
      ]
    },
    "summary": {
      "type": "string"
    },
    "dispatch": {
      "$ref": "#/definitions/workflow_dispatch"
    },
    "retry_after": {
      "type": "string"
    },
    "pr_url": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "artifacts": {}
  },
  "additionalProperties": false,
  "definitions": {
    "workflow_dispatch": {
      "type": "object",
      "required": [
        "workflow",
        "target",
        "inputs"
      ],
      "properties": {
        "workflow": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
