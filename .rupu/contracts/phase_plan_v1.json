{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "phase_plan_v1",
  "type": "object",
  "required": [
    "issue_ref",
    "summary",
    "phases"
  ],
  "properties": {
    "issue_ref": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "summary",
          "validation",
          "exit_criteria"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "validation": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "exit_criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
